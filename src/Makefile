# ConcurrentRBTree Source Makefile
# This is a header-only library, nothing to compile

.PHONY: all clean install

all:
	@echo "ConcurrentRBTree is a header-only library."
	@echo "No compilation needed."
	@echo ""

install:
	@echo "To use ConcurrentRBTree in your project:"
	@echo "  1. Add -I$(PWD)/include to your compiler flags"
	@echo "  2. Include as: #include <ConcurrentRBTree.h>"

clean:
	@echo "Nothing to clean for header-only library"
